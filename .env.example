# ============================================================================
# AI 服务配置（必需）
# ============================================================================

# DashScope API 密钥 - LLM 推理服务必需
DASHSCOPE_API_KEY=your-dashscope-api-key-here

# DashScope API 基础 URL - LLM 推理服务必需
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# DashScope 模型名称 - LLM 推理服务必需
# 示例：qwen3.5-397b-a17b, qwen-max, qwen-plus
DASHSCOPE_MODEL=qwen3.5-397b-a17b

# 启用 Thinking/Reasoning 模式 - 可选
# qwen3 系列模型支持返回思考过程，设置 true 可在 CLI 中显示
# DASHSCOPE_ENABLE_THINKING=true

# Exa 搜索 API 密钥 - 网络搜索工具必需
EXA_API_KEY=your-exa-api-key-here

# ============================================================================
# 数据目录配置（可选）
# ============================================================================
# 这些环境变量允许自定义各类数据存储位置

# 全局配置目录 - CLI 包使用
# 默认值：~/.thething（存放 config.json）
# THETHING_GLOBAL_CONFIG_DIR=/path/to/custom/config

# 全局数据目录 - CLI 包使用
# 默认值：~/.thething/data（存放 chat.db、logs、credentials 等）
# THETHING_GLOBAL_DATA_DIR=/path/to/custom/data

# 项目内存目录 - Core 包使用
# 默认值：<cwd>/.thething/memory（存放用户/团队记忆）
# THETHING_MEMORY_DIR=/path/to/custom/memory

# 项目 MCP 配置目录 - Core 包使用
# 默认值：<cwd>/.thething/mcps（存放 MCP Server 配置）
# THETHING_MCP_DIR=/path/to/custom/mcps

# ============================================================================
# Connector Gateway 配置（可选）
# ============================================================================

# 企业微信 Connector
# WECOM_CORP_ID=your-corp-id
# WECOM_CORP_SECRET=your-corp-secret
# WECOM_AGENT_ID=your-agent-id
# WECOM_TOKEN=your-webhook-token
# WECOM_ENCODING_AES_KEY=your-encoding-aes-key

# 飞书 Connector
# FEISHU_APP_ID=your-app-id
# FEISHU_APP_SECRET=your-app-secret
# FEISHU_ENCRYPT_KEY=your-encrypt-key
# FEISHU_VERIFICATION_TOKEN=your-verification-token

# ============================================================================
# 压缩配置（可选）
# ============================================================================

# 间隙阈值（分钟）
# 当（当前时间 - 最后一条助手消息）> 阈值时触发
# 默认值：60
# MICRO_COMPACT_GAP_THRESHOLD_MINUTES=60

# 保留最近的工具结果数量
# 默认值：5
# MICRO_COMPACT_KEEP_RECENT=5

# ============================================================================
# 说明
# ============================================================================
# 必需变量：
#   - DASHSCOPE_API_KEY、DASHSCOPE_BASE_URL、DASHSCOPE_MODEL - LLM 服务核心配置
#   - EXA_API_KEY - 网络搜索功能必需
#
# 可选变量：
#   - 数据目录配置（THETHING_*_DIR）- 自定义存储位置
#   - Connector Gateway（企业微信/飞书）- 消息推送功能
#   - 压缩配置 - 对话历史压缩策略
#
# 安全提示：
#   - 生产环境中请确保 DASHSCOPE_API_KEY 和 EXA_API_KEY 安全存储
#   - 不要将真实密钥提交到代码仓库
#
# 默认目录结构：
#   ~/.thething/               - 全局配置目录
#     config.json              - 用户配置
#   ~/.thething/data/          - 全局数据目录
#     chat.db                  - SQLite 数据库
#     logs/                    - 日志文件
#     credentials/             - 凭证存储
#   <project>/.thething/       - 项目目录
#     memory/                  - 内存存储
#     mcps/                    - MCP 配置
# ============================================================================