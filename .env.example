# ============================================================================
# AI 服务配置（必需）
# ============================================================================

# DashScope API 密钥 - LLM 推理服务必需
DASHSCOPE_API_KEY=your-dashscope-api-key-here

# DashScope API 基础 URL - LLM 推理服务必需
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# DashScope 模型名称 - LLM 推理服务必需
# 示例：qwen3.5-397b-a17b, qwen-max, qwen-plus
DASHSCOPE_MODEL=qwen3.5-397b-a17b

# Exa 搜索 API 密钥 - 网络搜索工具必需
EXA_API_KEY=your-exa-api-key-here

# ============================================================================
# 压缩配置（可选）
# ============================================================================

# 间隙阈值（分钟）
# 当（当前时间 - 最后一条助手消息）> 阈值时触发
# 默认值：60
# MICRO_COMPACT_GAP_THRESHOLD_MINUTES=60

# 保留最近的工具结果数量
# 默认值：5
# MICRO_COMPACT_KEEP_RECENT=5

# ============================================================================
# 说明
# ============================================================================
# - 必需变量必须设置才能使应用程序正常工作
# - 可选变量已注释并显示默认值
# - 压缩功能默认启用，除非显式禁用
# - 生产环境中请确保安全设置 DASHSCOPE_API_KEY 和 EXA_API_KEY
# ============================================================================