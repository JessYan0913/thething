# ============================================================================
# AI 服务配置（必需）
# ============================================================================

# DashScope API 密钥 - LLM 推理服务必需
DASHSCOPE_API_KEY=your-dashscope-api-key-here

# DashScope API 基础 URL - LLM 推理服务必需
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# DashScope 模型名称 - LLM 推理服务必需
# 示例：qwen3.5-397b-a17b, qwen-max, qwen-plus
DASHSCOPE_MODEL=qwen3.5-397b-a17b

# Exa 搜索 API 密钥 - 网络搜索工具必需
EXA_API_KEY=your-exa-api-key-here

# ============================================================================
# 系统提示词配置（可选）
# ============================================================================

# 启用简单模式用于测试/开发
# 默认值：false（禁用）
# CLAUDE_CODE_SIMPLE=true

# ============================================================================
# 压缩配置（可选）
# ============================================================================
# 所有压缩功能默认启用，取消注释以禁用或自定义。

# 禁用所有压缩（包括手动 /compact）
# 默认值：false（启用）
# DISABLE_COMPACT=true

# 仅禁用自动压缩（手动 /compact 仍然可用）
# 默认值：false（启用）
# DISABLE_AUTO_COMPACT=true

# 显式启用 Session Memory 压缩
# 默认值：false（默认禁用，可设置为 true 启用）
# ENABLE_SM_COMPACT=true

# 禁用 Session Memory 压缩
# 默认值：false（启用）
# DISABLE_SM_COMPACT=true

# 自定义自动压缩窗口（token 数，覆盖默认阈值）
# 默认值：0（使用默认阈值 100000）
# CLAUDE_CODE_AUTO_COMPACT_WINDOW=100000

# 基于百分比的触发阈值（0-100）
# 在上下文窗口容量的 X% 时触发压缩
# 默认值：0（禁用，使用 token 阈值代替）
# CLAUDE_AUTOCOMPACT_PCT_OVERRIDE=80

# ============================================================================
# MicroCompact 时间配置（可选）
# ============================================================================
# 调整 MicroCompact 如何处理对话中的时间间隙。

# 间隙阈值（分钟）
# 当（当前时间 - 最后一条助手消息）> 阈值时触发
# 默认值：60
# MICRO_COMPACT_GAP_THRESHOLD_MINUTES=60

# 保留最近的工具结果数量
# 默认值：5
# MICRO_COMPACT_KEEP_RECENT=5

# ============================================================================
# 说明
# ============================================================================
# - 必需变量必须设置才能使应用程序正常工作
# - 可选变量已注释并显示默认值
# - 压缩功能默认启用，除非显式禁用
# - 生产环境中请确保安全设置 DASHSCOPE_API_KEY 和 EXA_API_KEY
# ============================================================================