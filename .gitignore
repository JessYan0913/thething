# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*

# pnpm
.pnpm-debug.log*
pnpm-lock.yaml

# yarn (legacy)
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# workspace dependencies - ignore all node_modules in packages
packages/*/node_modules/
**/node_modules/

# testing
/coverage
**/coverage

# next.js
/.next/
/out/
.next/
out/

# production builds
/build/
dist/
**/build/
**/dist/

# exception: allow packages/build (portable build scripts)
!packages/build/

# misc
.DS_Store
*.pem
*.log

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# deployment
.vercel
.vercel-*

# typescript
*.tsbuildinfo
next-env.d.ts
**/*.tsbuildinfo

# runtime and data
.data/
connector-idempotency.db
.thething/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
Thumbs.db
.DS_Store?

# Temporary files
*.tmp
*.temp

# Cache
.cache/
.parcel-cache/
.eslintcache
