{
  "name": "thething",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:next": "pnpm --filter @the-thing/app dev",
    "dev:cli": "pnpm --filter @the-thing/cli dev",
    "build:next": "pnpm --filter @the-thing/app build",
    "build:cli": "pnpm --filter @the-thing/cli build",
    "build:desktop": "pnpm build:next && pnpm --filter @the-thing/desktop rebuild:sqlite && pnpm --filter @the-thing/desktop prepare:standalone && pnpm --filter @the-thing/desktop build",
    "dev:desktop": "pnpm --filter @the-thing/desktop dev",
    "start:next": "pnpm --filter @the-thing/app start",
    "cli": "pnpm --filter @the-thing/cli start",
    "lint": "eslint",
    "typecheck": "pnpm -r typecheck",
    "typecheck:core": "pnpm --filter @the-thing/core typecheck",
    "check:layers": "node scripts/check-layer-deps.mjs",
    "check:isolation": "node scripts/check-interface-isolation.mjs",
    "check:exports": "node scripts/check-export-surface.mjs"
  },
  "dependencies": {
    "@the-thing/core": "workspace:*"
  },
  "devDependencies": {
    "eslint": "^9",
    "typescript": "^5"
  }
}
