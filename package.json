{
  "name": "thething",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:server": "pnpm --filter @the-thing/server dev",
    "dev:web": "pnpm --filter @the-thing/web dev",
    "dev:cli": "pnpm --filter @the-thing/cli dev",
    "build:web": "pnpm --filter @the-thing/web build",
    "build:cli": "pnpm --filter @the-thing/cli build",
    "build:portable": "pnpm --filter @the-thing/build build:portable",
    "build:portable:macos": "pnpm --filter @the-thing/build build:portable:macos",
    "build:portable:win": "pnpm --filter @the-thing/build build:portable:win",
    "start:server": "pnpm --filter @the-thing/server start",
    "cli": "pnpm --filter @the-thing/cli start",
    "lint": "eslint",
    "typecheck": "pnpm -r typecheck",
    "typecheck:core": "pnpm --filter @the-thing/core typecheck"
  },
  "dependencies": {
    "@the-thing/core": "workspace:*"
  },
  "devDependencies": {
    "eslint": "^9",
    "typescript": "^5"
  }
}
