{
  "name": "@the-thing/cli",
  "version": "0.1.5",
  "bin": {
    "thething": "./dist/index.mjs"
  },
  "scripts": {
    "dev": "tsup --watch --onSuccess 'node dist/index.mjs'",
    "dev:run": "node dist/index.mjs",
    "build": "tsup",
    "release": "cd dist && npm publish --access public",
    "start": "cross-env NODE_NO_WARNINGS=1 tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@the-thing/core": "workspace:*",
    "ai": "^7.0.7",
    "better-sqlite3": "^12.8.0",
    "chalk": "^5.4.1",
    "cli-highlight": "^2.1.11",
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "ink": "^4.4.1",
    "ink-text-input": "^5.0.1",
    "marked": "^15.0.0",
    "nanoid": "^5.1.7",
    "open": "^10.1.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^18.3.0",
    "cross-env": "^7.0.3",
    "dotenv-cli": "^7.4.2",
    "esbuild": "^0.25.2",
    "tsup": "^8.5.1",
    "tsx": "^4.19.3",
    "typescript": "^5"
  }
}
