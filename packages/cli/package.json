{
  "name": "@the-thing/cli",
  "version": "0.1.5",
  "bin": {
    "thething": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "release": "cd dist && npm publish --access public",
    "start": "cross-env NODE_NO_WARNINGS=1 tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@hono/node-server": "^1.14.4",
    "@thething/core": "workspace:*",
    "@thething/server": "workspace:*",
    "ai": "^6.0.149",
    "better-sqlite3": "^12.8.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "nanoid": "^5.1.7",
    "open": "^10.1.0",
    "ora": "^8.2.0",
    "readline": "^1.3.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "cross-env": "^7.0.3",
    "dotenv-cli": "^7.4.2",
    "esbuild": "^0.25.2",
    "tsup": "^8.5.1",
    "tsx": "^4.19.3",
    "typescript": "^5"
  }
}
