{
  "name": "@the-thing/desktop",
  "version": "0.1.0",
  "private": true,
  "main": "build/main.js",
  "scripts": {
    "dev": "electron .",
    "build": "pnpm prepare:standalone && tsc -p tsconfig.json && electron-builder",
    "prepare:standalone": "tsx scripts/prepare-standalone.ts",
    "rebuild:sqlite": "electron-rebuild -f -w better-sqlite3 -m ../app"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.0",
    "@types/node": "^20",
    "electron": "^35.0.0",
    "electron-builder": "26.8.1",
    "tsx": "^4.19.3",
    "@typescript/native": "npm:typescript@^7.0.2",
    "typescript": "npm:@typescript/typescript6@^6.0.2"
  }
}
