{
  "$schema": "https://raw.githubusercontent.com/nicoverbruggen/tauri-v2-schema/main/tauri.conf.schema.json",
  "productName": "The Thing",
  "version": "0.1.0",
  "identifier": "com.thething.desktop",
  "build": {
    "devUrl": "http://localhost:5173",
    "frontendDist": "../loading"
  },
  "app": {
    "windows": [
      {
        "title": "The Thing",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:*; script-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/thing"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
